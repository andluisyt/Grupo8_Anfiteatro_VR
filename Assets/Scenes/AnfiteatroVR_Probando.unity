    - target: {fileID: 4221711074479977579, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_text
      value: "<b>Disposici\xF3n:</b> Venas profundas sat\xE9lites dobles que acompa\xF1an
        a la arteria tibial posterior en el compartimento posterior de la pierna.
        Ascienden desde el canal calc\xE1neo y terminan en el anillo del s\xF3leo
        uni\xE9ndose con las venas tibiales anteriores para formar la vena popl\xEDtea."
      objectReference: {fileID: 0}
