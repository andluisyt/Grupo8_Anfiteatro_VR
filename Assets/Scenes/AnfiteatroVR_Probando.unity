    - target: {fileID: 2810633154391219660, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_text
      value: "<b>Origen y Relaci\xF3n de Superficialidad:</b> Se origina en el borde
        inferior del m\xFAsculo popl\xEDteo por la uni\xF3n de las venas tibiales.
        Asciende por la fosa popl\xEDtea, situ\xE1ndose de manera constante **superficial**
        (posterior) a la arteria popl\xEDtea.\r\n\r\n<b>Terminaci\xF3n:</b> Termina
        al cruzar el hiato del aductor para convertirse en vena femoral."
      objectReference: {fileID: 0}
