    - target: {fileID: 9070780544609070541, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_text
      value: "<b>Disposici\xF3n:</b> Venas profundas sat\xE9lites dobles que acompa\xF1an
        a la arteria tibial anterior en el compartimento anterior de la pierna. Perforan
        la parte superior de la membrana inter\xF3sea junto a la arteria para unirse
        a las venas tibiales posteriores."
      objectReference: {fileID: 0}
    - target: {fileID: 9070780544609070541, guid: 59889190ffbc2334281e67e6cef80a4f,
