    - target: {fileID: 1866783837604796723, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_text
      value: "<b>Disposici\xF3n profunda:</b> Venas profundas sat\xE9lites (dobles)
        que acompa\xF1an a la arteria radial en la cara lateral del antebrazo. Se
        originan en los arcos venosos de la mano y terminan uni\xE9ndose con las
        venas cubitales en la flexura del codo."
      objectReference: {fileID: 0}
