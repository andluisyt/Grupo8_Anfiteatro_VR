    - target: {fileID: 4974535778298901009, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_text
      value: "Bifurcaci\xF3n: Al llegar al borde superior del cart\xEDlago tiroides
        (aproximadamente a la altura de la v\xE9rtebra C4), se divide en sus dos
        ramas terminales:\n\nCar\xF3tida Interna: Sube directo al cr\xE1neo sin dar
        ramas en el cuello, encarg\xE1ndose de irrigar el cerebro.\n\nCar\xF3tida
        Externa: Irriga las estructuras de la cara, el cuello y el cuero cabelludo.\n\n\n\n"
      objectReference: {fileID: 0}
