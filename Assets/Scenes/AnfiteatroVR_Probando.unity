    - target: {fileID: 7423634459062468464, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_text
      value: "\nOrigen: Tercio lateral de la clav\xEDcula.\r\nInserci\xF3n: Tuberosidad
        deltoidea.\r\nFunci\xF3n: Flexi\xF3n y rotaci\xF3n interna del brazo.\r\nInervaci\xF3n:
        Nervio axilar.\r\nIrrigaci\xF3n: Arteria circunfleja humeral posterior.\r\nImportancia
        Cl\xEDnica: Lesi\xF3n \u2192 dificultad para elevar el brazo."
      objectReference: {fileID: 0}
