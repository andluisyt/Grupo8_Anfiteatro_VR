    - target: {fileID: 1784251851741590976, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_SizeDelta.x
      value: -120
      objectReference: {fileID: 0}
    - target: {fileID: 1784251851741590976, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_AnchoredPosition.x
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 1784251851741590977, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_Layer
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 1784251851741590979, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_text
      value: "<b>Origen y Trayecto Superficial:</b> Es una de las venas superficiales
        principales del miembro superior. Se origina en la red venosa dorsal de la
        mano (lado cubital) y asciende por la cara medial del antebrazo y el brazo.\r\n\r\n<b>Perforaci\xF3n
        Aponeur\xF3tica y Terminaci\xF3n:</b> A nivel del tercio medio/inferior del
        brazo, perfora la fascia braquial profunda para hacerse profunda. Termina
        uni\xE9ndose a las venas braquiales para formar la vena axilar."
      objectReference: {fileID: 0}
    - target: {fileID: 1784251851741590979, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
