    - target: {fileID: 6159361965637816618, guid: 59889190ffbc2334281e67e6cef80a4f,
        type: 3}
      propertyPath: m_text
      value: "<b>Origen y Relaciones:</b> Continuaci\xF3n de la arteria femoral a
        partir del hiato del aductor. Atraviesa verticalmente y en profundidad la
        fosa popl\xEDtea (regi\xF3n posterior de la rodilla), estando \xEDntimamente
        relacionada con la cara posterior de la c\xE1psula articular.\r\n\r\n<b>Bifurcaci\xF3n:</b>
        Finaliza en el borde inferior del m\xFAsculo popl\xEDteo (anillo del s\xF3leo),
        donde se divide en sus dos ramas terminales:\r\n\u2022 <i>Arteria Tibial
        Anterior.</i>\r\n\u2022 <i>Tronco Tibioperoneo</i> (el cual dar\xE1 origen
        a la arteria tibial posterior y peronea)."
      objectReference: {fileID: 0}
